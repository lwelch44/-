{
  "name": "one-person-group",
  "version": "1.0.0",
  "description": "一人集团多智能体系统 - Windows桌面版",
  "main": "src/main.js",
  "author": "lwelch44",
  "scripts": {
    "start": "electron .",
    "package": "npx electron-builder --win --x64"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.onepersongroup.desktop",
    "productName": "一人集团",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}