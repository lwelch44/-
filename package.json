{
  "name": "one-person-group",
  "version": "1.0.0",
  "description": "一人集团多智能体系统 - Windows桌面版",
  "main": "src/main.js",
  "author": "lwelch44",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --win --x64"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.onepersongroup.desktop",
    "productName": "OnePersonGroup",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}